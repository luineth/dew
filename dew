#!/usr/bin/gawk -f

# USAGE: pipe your to.dew list to this executable.
# If the .vim files are installed, use <local leader> + f
# from within a .dew file, or run :%! path/to/dew
# to filter in place.

# Depends on GNU coreutils date.

BEGIN {
    # grab today's date YYYY-MM-DD
    "date +%F" | getline today
    close("date +%F")

    DATE_RE = "[0-9]{4}-[0-9]{2}-[0-9]{2}"

    DURATION_RE = "[0-9]+(d|w|m|y)"
    WEEKDAY_RE = "(sun|mon|tue|wed|thu|fri|sat)"

    DEFER_RE = "(>" DURATION_RE "|>" WEEKDAY_RE ")\\>"

    REPEAT_DURATION_RE = "+{1,2}" DURATION_RE
    INVALID_DURATION_RE = "+{1,2}[0-9]+[^dwmy]"
    REPEAT_WEEKDAY_RE = "+{2}" WEEKDAY_RE # only relative repeats supported
    INVALID_WEEKDAY_RE = "+" WEEKDAY_RE
    REPEAT_RE = "(" REPEAT_DURATION_RE "|" REPEAT_WEEKDAY_RE ")\\>"

    print ": -- dew task filter --"
    #print ": for help topics, add a hyphen to a blank line, then rerun dew"
    help["help"] = "under construction!\n" \
        "check later"
}

/^-/ { print; process_help(); next }

## Cleanup ##

# strip leading and trailing whitespace
{ gsub(/(^[ \t]+|[ \t]+$)/, "") }

# skip machine comments
/^:/ { next }

# collapse multi-line spacing
!NF {
    if (prev_line_is_blank) next
    prev_line_is_blank = 1
}
NF { prev_line_is_blank = 0 }

# defer macro
$0 ~ DEFER_RE {
    defer_expr = extract(DEFER_RE, $0)
    gsub(/>/, "", defer_expr)
    if (defer_expr ~ WEEKDAY_RE)
        new_date = dow_offset(defer_expr)
    else
        new_date = duration_offset(today, defer_expr)

    gsub(DATE_RE, "") # kill any old date
    sub(DEFER_RE, new_date)
    gsub(DEFER_RE, "") # kill any duplicate defers
}

## Non-Project tasks ##

# directly cache to inbox and someday to respective outputs
/^\?/ { output["inbox"][++output_n["inbox"]] = $0; next }
/^&/ { output["someday"][++output_n["someday"]] = $0; next }

## Project logic ##

# headers
/^#/   { header[++header_n] = $0; next }

# repeat handler
$0 ~ REPEAT_RE && /^~.+[^~]$/ {
    # pick a lane
    if ($0 ~ REPEAT_WEEKDAY_RE && $0 ~ REPEAT_DURATION_RE) {
        task_lint("Duration and weekday repeats are mutually exclusive: e.g. ++tue ^ +1w")
        done[++done_n] = $0 # keep line w/ warning in place
        next
    }

    repeat_expr = extract(REPEAT_RE, $0)
    if (repeat_expr ~ REPEAT_WEEKDAY_RE) {
        # these repeats never anchored
        gsub(/+/, "", repeat_expr)
        new_date = dow_offset(repeat_expr)
    } else {
        # duration repeats:
        repeat_from = today #default, unless...
        # date available & anchored repeat
        if ($0 ~ DATE_RE && repeat_expr !~ /+{2}/)
            repeat_from = extract(DATE_RE,$0)

        gsub(/+/, "", repeat_expr)
        new_date = duration_offset(repeat_from, repeat_expr)
    }

    # store cancelled task
    done[++done_n] = $0 "~"

    sub(/^~/, "$") # activate
    gsub(DATE_RE, "") # delete any old dates
    $0 = $0 " " new_date
    # fall through
}

$0 ~ INVALID_WEEKDAY_RE || $0 ~ INVALID_DURATION_RE {
    task_lint("Looks like a malformed repeat expression.")
}

/^~/ { done[++done_n] = $0; next }

/^[%$]/ && $0 !~ DATE_RE {
    task_lint("No follow-up date. Assign one with YYYY-MM-DD or a shortcut, e.g. '>2w'.")
}

/^%/ {
    if ($1 == "%")
        task_lint("Delegated to whom? Use '%person'.")
    else
        delegated_to[$1]++
}

# activate any due dates
/^[%$]/ && $0 ~ DATE_RE {
    date_string = extract(DATE_RE, $0)

    if(date_string <= today)
        $0 = ">" $0
}

# downgrade deferred next actions
/^>/ && $0 ~ DATE_RE {
    date_string = extract(DATE_RE, $0)

    if(date_string > today)
        sub(/>/, "$")
}

/^\$/ { scheduled[++scheduled_n] = $0; next }
/^%/  { delegated[++delegated_n] = $0; next }

# record contexts from next tasks
/^>.*@.+/ {
    for(i = 1; i <= NF; i++) {
        if(match($i, /^@.+$/)) {
            contexts[$i]++
        }
    }
}

# 'next' is reserved; referred to as "workable" in codebase
/^>/ { workable[++workable_n] = $0; next }

# any non-matched items: indent then cache
NF {
    $0 = " " $0
    pending[++pending_n] = $0
    next
}

# line must be blank to continue:
# blanks are implicit end of project
{ cache_project() }


END {
    cache_project() # guards against files not ending in \n

    # these sections aren't generated via cache_project_as(),
    # so they need a line feed to sep from later sections
    inbox_n = output_n["inbox"] # prevent off by one from following:
    output["inbox"][++output_n["inbox"]] = ""
    output["someday"][++output_n["someday"]] = ""

    if (lints)
        print ": lints: " lints "\n: Search for ':!' to correct.\n"

    print ": inbox: " (inbox_n ? inbox_n : "empty!")

    if(isarray(contexts)) {
        print ": context counts:"
        for (i in contexts)
            print ":\t" i ": " contexts[i]
    }
    if(isarray(delegated_to)) {
        print ": delegated counts:"
        for (i in delegated_to)
            print ":\t" i ": " delegated_to[i]
    }
    print ""

    section[1] = "inbox"
    section[2] = "live"
    section[3] = "dormant"
    section[4] = "someday"
    section[5] = "completed"

    for( i = 1; i <= 5; i++) {
        sec = section[i]
        
        print ": " sec
        for(j = 1; j <= output_n[sec]; j++) {
            print output[sec][j]
        }
    }
}

function cache_project() {
    if (workable_n) {
        cache_project_as("live")
        return
    }

    if (delegated_n || scheduled_n) {
        cache_project_as("dormant")
        return
    }

    # no follow-up and not completed
    if (pending_n || (header_n && !done_n)) {
        cache_project_as("live", "Project is stalled. Assign a next action or follow-up.")
        return
    }

    # possible header and >1 done:
    if (done_n) {
        cache_project_as("completed")
        return
    }

    # no tasks at all: do nothing
    return
}

function cache_project_as(section, lint) {
    # store any project lint warnings
    if (lint) {
        output[section][++output_n[section]] = ":! " lint
        lints++
    }
    
    # transfer projects to their output section
    append_section(section, header, header_n)
    append_section(section, workable, workable_n)
    append_section(section, delegated, delegated_n)
    append_section(section, scheduled, scheduled_n)
    append_section(section, pending, pending_n)
    append_section(section, done, done_n)

    output[section][++output_n[section]] = ""

    clear_project_cache()
}

function append_section(section, arr, count,    i) {
    for (i = 1; i <= count; i++) {
        output[section][++output_n[section]] = arr[i]
    }
}

function clear_project_cache() {
    delete header
    delete done
    delete workable
    delete delegated
    delete scheduled
    delete pending

    header_n = done_n = workable_n = delegated_n = scheduled_n = pending_n = 0
}

function duration_offset(repeat_from, repeat_expr,  cmd, result) {
    # repeat_expr is necessarily (int)(duration), e.g. "2w"
    # expand to make `date` happy
    # NB: trailing space neutralizes subsequent sub()s
    # to prevent "1d" -> "1 day" -> "1 da year"
    sub(/d$/, " day ",   repeat_expr)
    sub(/w$/, " week ",  repeat_expr)
    sub(/m$/, " month ", repeat_expr)
    sub(/y$/, " year ",  repeat_expr)

    cmd = "date -d '" repeat_from " +" repeat_expr "' +%F"
    cmd | getline result
    close(cmd)
    return result
}

function dow_offset(dow,  cmd, result) {
    cmd = "date -d 'next " dow "' +%F"
    cmd | getline result
    close(cmd)
    return result
}

function extract(pattern, string) {
    if (match(string, pattern))
        return substr(string, RSTART, RLENGTH)
    return ""
}

function task_lint(msg) {
    $0 = $0 "\n:! " msg
    lints++
}

function process_help(    topic, arg) {
    # extract topic & sanitize
    arg = substr($0, 2)
    gsub(/[^a-z]/, "", arg)

    if (arg == "") {
        print_help_index()
    } else if (arg in help) {
        print ":- " arg
        print help[arg]
    } else {
        print ":- unknown topic: " arg
        print_help_index()
    }
}

function print_help_index() {
    print ":- help topic index:"
    print ":- access topic with '-topic' on a blank line"
    for(topic in help)
        print ":-\t-" topic
}

function print_help_text(text,    lines, n, i) {
    n = split(text, lines, "\n")
    for(i = 1; i <= n; i++)
        print ":- " lines[i]
}
#!/usr/bin/gawk -f

# USAGE: pipe your to.dew list to this executable.
# If the .vim files are installed, use <local leader> + f
# from within a .dew file, or run :%! path/to/dew
# to filter in place.

# Depends on GNU coreutils date.

BEGIN {
    # grab today's date YYYY-MM-DD
    "date +%F" | getline today
    close("date +%F")

    date_regex = "[0-9]{4}-[0-9]{2}-[0-9]{2}"

    # gawk infers initial plus is literal
    duration = "[0-9]+(d|w|m|y)"
    weekday = "(sun|mon|tue|wed|thu|fri|sat)"

    defer_regex = "(>" duration "|>" weekday ")"

    repeat_duration = "+{1,2}" duration
    repeat_weekday = "+{2}" weekday # only relative repeats supported
    repeat_regex = "(" repeat_duration "|" repeat_weekday ")"
}

## Cleanup
# strip leading and trailing whitespace
{ gsub(/(^[ \t]+|[ \t]+$)/, "") }

# skip stray one-character lines
/^.$/ { next }

# skip machine comments
/^:/ { next }

# collapse multi-line spacing
!NF {
    if (prev_line_is_blank) next
    prev_line_is_blank = 1
}
NF { prev_line_is_blank = 0 }

# Defer macro
$0 ~ defer_regex {
    match($0, defer_regex)
    defer_expr = substr($0, RSTART, RLENGTH)
    gsub(/>/, "", defer_expr)
    if (defer_expr ~ weekday)
        new_date = dow_offset(defer_expr)
    else
        new_date = duration_offset(today, defer_expr)

    sub(defer_regex, new_date, $0)
    # kill any duplicates, only leftmost expr processed
    gsub(defer_regex, "", $0)
}

## Special sections
# directly cache to inbox and someday to respective outputs
/^\?/ { output["inbox"][++output_n["inbox"]] = $0; next }
/^&/ { output["someday"][++output_n["someday"]] = $0; next }

## Task is a bona fide project:
# headers
/^#/   { header[++header_n] = $0; next }

# repeat handler
$0 ~ repeat_regex && /^~.+[^~]$/ {

    # no crossing streams
    if ($0 ~ repeat_weekday && $0 ~ repeat_duration) {
        $0 = $0 "\n:! Duration and weekday repeats are mutually exclusive: e.g. ++tue ^ +1w"
        lints++
        done[++done_n] = $0 # keepline w/ warning in place
        next
    }

    # extract leftmost repeat expression;
    # syntax highlights only leftmost
    match($0, repeat_regex)
    repeat_expr = substr($0, RSTART, RLENGTH)

    if (repeat_expr ~ repeat_weekday) {
        # never anchored repeat
        gsub(/+/, "", repeat_expr)
        new_date = dow_offset(repeat_expr)
    } else {
        # duration repeats:

        repeat_from = today #default, unless...
        # date available & anchored repeat
        if ($0 ~ date_regex && repeat_expr !~ /+{2}/) {
            match($0, date_regex)
            repeat_from = substr($0, RSTART, RLENGTH)
        }

        gsub(/+/, "", repeat_expr)
        new_date = duration_offset(repeat_from, repeat_expr)
    }

    # store cancelled task
    done[++done_n] = $0 "~"

    sub(/^~/, "$") # activate
    gsub(date_regex, "") # delete any old dates
    $0 = $0 " " new_date
    # fall through
}

/^~/ { done[++done_n] = $0; next }

/^[%$]/ && $0 !~ date_regex {
    $0 = $0 "\n:! No follow-up date assigned.\n: Assign one with YYYY-MM-DD or a shortcut, e.g. (>2w)."
    lints++
}

/^%/ {
    if ($1 == "%") {
        $0 = $0 "\n:! Delegated to whom?"
        lints++
    }
    else
        delegated_to[$1]++
}


# activate any due dates
/^[%$]/ && $0 ~ date_regex {
    match($0, date_regex)
    date_string = substr($0, RSTART, RLENGTH)

    if(date_string <= today)
        $0 = ">" $0
}

# downgrade deferred next actions
/^>/ && $0 ~ date_regex {
    match($0, date_regex)
    date_string = substr($0, RSTART, RLENGTH)

    if(date_string > today)
        sub(/>/, "$", $0)
}

/^\$/ { scheduled[++scheduled_n] = $0; next }
/^%/  { delegated[++delegated_n] = $0; next }

# record contexs from next tasks
/^>.*@.+/ {
    for(i = 1; i <= NF; i++) {
        if(match($i, /^@.+$/)) {
            contexts[$i]++
        }
    }
}

# 'next' is reserved; referred to as "workable" in codebase
/^>/ { workable[++workable_n] = $0; next }

# any non-matched items: indent then cache
NF {
    $0 = " " $0
    pending[++pending_n] = $0
    next
}

# line must be blank to continue:
# blanks are implicit end of project
{ cache_project() }


END {
    cache_project() # guards against files not ending in \n

    # these sections aren't generated via cache_project_as(),
    # so they need a line feed to sep from later sections
    output["inbox"][++output_n["inbox"]] = ""
    output["someday"][++output_n["someday"]] = ""

    if (lints)
        print ": lints: " lints "\n: Search for ':!' to correct.\n"

    print ": inbox:", output_n["inbox"]

    print ": context counts:"
    for (i in contexts)
        print ":\t" i ": " contexts[i]
    print ": delegated counts:"
    for (i in delegated_to)
        print ":\t" i ": " delegated_to[i]
    printf("\n")

    section[1] = "inbox"
    section[2] = "live"
    section[3] = "dormant"
    section[4] = "someday"
    section[5] = "completed"

    for( i = 1; i <= 5; i++) {
        sec = section[i]
        print ": " section[i]
        for(j = 1; j <= output_n[section[i]]; j++) {
            print output[section[i]][j]
        }
    }
}

function cache_project() {
    if (workable_n) {
        cache_project_as("live")
        return
    }

    if (delegated_n || scheduled_n) {
        cache_project_as("dormant")
        return
    }

    # no follow-up and not completed
    if (pending_n || (header_n && !done_n)) {
        cache_project_as("live", ":! Project is stalled. Assign a next action or follow-up.")
        lints++
        return
    }

    # possible header and >1 done:
    if (done_n) {
        cache_project_as("completed")
        return
    }

    # no tasks at all: do nothing
    return
}

function cache_project_as(section, lint) {
    # store any lints
    if (lint)
        output[section][++output_n[section]] = lint
    
    # transfer projects to their output section
    append_section(section, header, header_n)
    append_section(section, workable, workable_n)
    append_section(section, delegated, delegated_n)
    append_section(section, scheduled, scheduled_n)
    append_section(section, pending, pending_n)
    append_section(section, done, done_n)

    output[section][++output_n[section]] = ""

    clear_project_cache()
}

function append_section(section, arr, count,    i) {
    for (i = 1; i <= count; i++) {
        output[section][++output_n[section]] = arr[i]
    }
}

function clear_project_cache() {
    delete header
    delete done
    delete workable
    delete delegated
    delete scheduled
    delete pending

    header_n = done_n = workable_n = delegated_n = scheduled_n = pending_n = 0
}

function duration_offset(repeat_from, repeat_expr,  cmd, result) {
    # repeat_expr is necessarily (int)(duration), e.g. "2w"
    # expand to make `date` happy
    # NB: trailing space neutralizes subsequent sub()s
    # to prevent "1d" -> "1 day" -> "1 da year"
    sub(/d$/, " day ",   repeat_expr)
    sub(/w$/, " week ",  repeat_expr)
    sub(/m$/, " month ", repeat_expr)
    sub(/y$/, " year ",  repeat_expr)

    cmd = "date -d '" repeat_from " +" repeat_expr "' +%F"
    cmd | getline result
    close(cmd)
    return result
}

function dow_offset(dow,  cmd, result) {
    cmd = "date -d 'next " dow "' +%F"
    cmd | getline result
    close(cmd)
    return result
}